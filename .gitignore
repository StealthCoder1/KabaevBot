# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment files (keep example)
.env
.env.*
!.env.example

# IDE/editor settings
.idea/
.vscode/

# Test, lint, and type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/

# Packaging/build artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Coverage artifacts
.coverage
.coverage.*
htmlcov/

# Logs and runtime files
*.log
Data/log.log
*.pid

# OS files
Thumbs.db
Desktop.ini
.DS_Store

# Local databases (if generated)
*.sqlite3
*.db
